{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "melody-hub",
  "version": "0.1.1",
  "identifier": "com.melody-hub.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://127.0.0.1:5420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Melody Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:* https:; font-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDMTk2RTNGRDNGODA5MTUKUldRVkNmalRQMjRaL0NObmZ6T2UralhnSktONnBSUzFtckdCcFZJdlFJdzIxYmdTV2JhWmpodVcK",
      "endpoints": [
        "https://github.com/Lhy723/MelodyHub/releases/latest/download/{{target}}-{{arch}}-{{current_version}}"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
